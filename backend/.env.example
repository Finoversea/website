# FinOversea Environment Variables Template
# Copy to .env and fill in your values

# Application
DEBUG=true
APP_NAME=FinOversea
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finoversea

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
# IMPORTANT: Set your actual OpenAI API key
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Collector settings
COLLECTOR_USER_AGENT=FinOversea/1.0 (舆情采集)
COLLECTOR_TIMEOUT=30
COLLECTOR_MAX_CONCURRENT=10

# Push settings
PUSH_BATCH_SIZE=100
PUSH_RETRY_COUNT=3

# Tagging settings
TAG_CONFIDENCE_THRESHOLD=0.7