# .dockerignore for FinOversea Backend
# Reduce image size by excluding unnecessary files

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Tests
tests/
*.test.py
test_*.py
*_test.py
.pytest_cache/
.coverage
htmlcov/

# Documentation
docs/
*.md
README.md
LICENSE

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile
docker-compose*.yml
.docker/

# Kubernetes
deploy/
k8s/
*.yaml
*.yml

# Config files
.env*
config/*.env

# Misc
*.log
*.tmp
.DS_Store
Thumbs.db