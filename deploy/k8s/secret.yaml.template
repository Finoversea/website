# FinOversea Secrets Template
# IMPORTANT: Do NOT commit this file with real secrets!
# Use sealed-secrets, vault, or external-secrets for production
#
# For local testing, create from this template:
#   kubectl create secret generic finoversea-secrets \
#     --from-literal=DATABASE_URL='postgresql+asyncpg://postgres:PASSWORD@postgres-host:5432/finoversea' \
#     --from-literal=OPENAI_API_KEY='sk-your-api-key' \
#     -n finoversea

apiVersion: v1
kind: Secret
metadata:
  name: finoversea-secrets
  namespace: finoversea
  labels:
    app: finoversea
type: Opaque
stringData:
  # Database connection URL (with credentials)
  # Replace PASSWORD with actual database password
  # Example: postgresql+asyncpg://finoversea:PASSWORD@postgres-service:5432/finoversea
  DATABASE_URL: "postgresql+asyncpg://finoversea:CHANGE_ME@postgres-service:5432/finoversea"

  # OpenAI API Key
  # Replace with actual API key
  OPENAI_API_KEY: "CHANGE_ME"